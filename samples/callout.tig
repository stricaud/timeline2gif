# samples/callout.tig  — callout spotlight demonstration
#
# Before each event joins the timeline a centred shape fades in,
# pauses so the viewer can read it, then exits with a configurable effect.
#
# Global shape (applies to all events unless overridden):
#   callout.shape  rectangle    sharp-cornered box
#   callout.shape  rounded      softly curved box  (used here)
#   callout.shape  cloud        bumpy cloud silhouette
#
# Per-event exit effect (event.callout_effect overrides callout.effect):
#   callout.effect / event.callout_effect:
#     none     — plain fade-out, no movement
#     funnel   — shape contracts toward the event dot on the timeline
#     zoom     — shape scales to zero at its centre
#     float    — shape drifts upward while fading
#     fan      — shape spins (2.5 rotations) while contracting to the dot
#
# Run from the repo root:
#   ./build/src/timeline2gif  samples/callout.tig  samples/callout.webp

# ── Canvas ──────────────────────────────────────────────────────────────
image.width  1000
image.height 460

# ── Midnight-teal theme ──────────────────────────────────────────────────
theme.background  argb(255,6,12,28)
theme.background2 argb(255,3,7,18)
theme.accent      argb(255,0,210,190)
theme.text        argb(255,210,240,235)

# ── Layout ───────────────────────────────────────────────────────────────
timeline.position 230

description.font_size 13
time.font_size        10

# ── Animation ────────────────────────────────────────────────────────────
speed.frames     4
speed.nextitem   60
speed.loop_pause 1000    # 10-second pause on the final frame before looping
camera.scroll    yes

# Time-based auto-positioning — no event.x needed.
# The year in each time string is extracted automatically.
# time.origin defaults to the first event's year.
time.format  year
item.spacing 48           # pixels per year; 3-year gap = 144 px on screen

# ── Callout spotlight ────────────────────────────────────────────────────
callout.shape   rounded
callout.pause   150       # centiseconds — 1.5 s per event
callout.effect  funnel    # default exit effect (overridden per-event below)
callout.color   argb(255,5,18,38)
callout.border  argb(255,0,210,190)

# ── Progress bar ─────────────────────────────────────────────────────────
progress.show   yes
progress.color  argb(255,0,210,190)

# ════════════════════════════════════════════════════════════════════════
# Events — x positions computed automatically from the year.
# Exit effects cycle through all four options so you can compare them.
# ════════════════════════════════════════════════════════════════════════

# effect: funnel  — shape contracts to the dot on the timeline
event.callout_effect funnel
event.dot_color  argb(255,0,210,190)
event.text_color argb(255,160,255,240)
"1990" "Tim Berners-Lee proposes the World Wide Web"

# effect: zoom  — shape scales to zero at its centre
event.callout_effect zoom
event.image      "icons/star.svg"
event.image_size 24
event.dot_color  argb(255,255,200,80)
event.text_color argb(255,255,230,140)
"1993" "Mosaic browser — the Web goes visual"

# effect: float  — shape drifts upward while fading
event.callout_effect float
event.dot_color  argb(255,100,180,255)
event.text_color argb(255,160,210,255)
"1995" "Amazon · Java · JavaScript launch"

# effect: none  — plain fade-out, no movement
event.callout_effect none
event.image      "icons/rocket.svg"
event.image_size 26
event.dot_color  argb(255,255,100,100)
event.text_color argb(255,255,160,160)
"1998" "Google founded"

# Cycle repeats — funnel
event.callout_effect funnel
event.dot_color  argb(255,180,140,255)
event.text_color argb(255,210,180,255)
"2001" "Wikipedia — free knowledge for all"

# zoom
event.callout_effect zoom
event.image      "icons/flag.svg"
event.image_size 24
event.dot_color  argb(255,80,160,255)
event.text_color argb(255,140,200,255)
"2004" "Facebook · Firefox · Gmail"

# float
event.callout_effect float
event.image      "icons/star.svg"
event.image_size 26
event.dot_color  argb(255,255,160,60)
event.text_color argb(255,255,200,120)
"2007" "iPhone · AWS S3 — cloud era begins"

# none
event.callout_effect none
event.dot_color  argb(255,255,80,160)
event.text_color argb(255,255,140,200)
"2010" "Instagram · iPad · Kubernetes seeds"

# funnel (large 5-year gap → fast camera sprint before callout)
event.callout_effect funnel
event.image      "icons/shield.svg"
event.image_size 26
event.dot_color  argb(255,60,230,140)
event.text_color argb(255,120,255,190)
"2015" "TensorFlow · React Native — AI goes open"

# zoom (7-year gap → dramatic sprint)
event.callout_effect zoom
event.image      "icons/rocket.svg"
event.image_size 28
event.dot_color  argb(255,0,210,190)
event.text_color argb(255,100,255,240)
event.line_color argb(255,0,180,160)
"2022" "ChatGPT · generative AI goes mainstream"
